<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="comboBox.MainWindow"
        Title="comboBox">
    <StackPanel Margin="10">
        <TextBlock Text="Select your favorite fruit:" FontSize="16" Margin="0,0,0,10"/>
        <ComboBox x:Name="FruitComboBox" SelectionChanged="FruitComboBox_SelectionChanged">
            <ComboBoxItem Content="Apple"/>
            <ComboBoxItem Content="Banana"/>
            <ComboBoxItem Content="Cherry"/>
            <ComboBoxItem Content="Date"/>
            <ComboBoxItem Content="Elderberry"/>
        </ComboBox>
        <TextBlock x:Name="SelectedFruitTextBlock" FontSize="14" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
