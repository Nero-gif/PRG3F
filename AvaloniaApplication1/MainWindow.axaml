<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaApplication1.MainWindow"
        Title="AvaloniaApplication1">
    <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock>What is your name?</TextBlock>
        <TextBox x:Name="NameTextBox" />
        <CheckBox x:Name="AcceptCheckBox" Content="Accept everything" />
        <Button Content="Hello" HorizontalAlignment="Center" Click="OnGreetButtonClick" />
        <TextBlock x:Name="GreetingTextBlock" Classes="welcome" HorizontalAlignment="Center"></TextBlock>
    </StackPanel>
</Window>
