<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        x:Class="multiWindows.ConfirmationWindow"
        Title="Confirmation">
    <StackPanel Spacing="10" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Name="InfoTextBlock" FontSize="16"/>
        <TextBlock Name="CountdownTextBlock" FontSize="14" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
